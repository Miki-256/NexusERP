{
  "name": "nex",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "PORT=3003 npm run dev -w @nex/web",
    "build": "npm run build -w @nex/web",
    "lint": "npm run lint -w @nex/web",
    "typecheck": "npm run typecheck -w @nex/web",
    "verify:supabase": "node scripts/verify-supabase-migrations.mjs",
    "db:baseline": "node scripts/db-baseline.mjs",
    "phase1:db": "node scripts/phase1-stabilize.mjs",
    "phase2:db": "node scripts/phase2-scale.mjs",
    "phase3:db": "node scripts/phase3-scale.mjs",
    "phase3:load": "node scripts/phase3-load-test.mjs",
    "week1:production": "node scripts/week1-production.mjs",
    "week2:production": "node scripts/week2-production.mjs",
    "week3:production": "node scripts/week3-production.mjs",
    "month2:production": "node scripts/month2-production.mjs",
    "cron:process-queue": "bash scripts/cron-process-queue.sh",
    "db:push": "npx supabase@latest db push",
    "setup:telegram": "node scripts/setup-telegram.mjs",
    "flush:notifications": "node scripts/flush-notifications.mjs",
    "repair:notifications": "node scripts/repair-notifications.mjs",
    "db:notifications": "node scripts/apply-notification-migrations.mjs",
    "vercel:telegram-env": "node scripts/set-vercel-telegram-env.mjs",
    "vercel:launch-env": "node scripts/set-vercel-launch-env.mjs",
    "sync:cron-secret": "node scripts/sync-cron-secret.mjs --apply-github",
    "vercel:sentry-env": "node scripts/set-sentry-env.mjs --push-vercel",
    "db:types": "npx supabase@latest gen types typescript --project-id vshtfxebkqmwhgrczqbb > apps/web/src/types/database.generated.ts",
    "load-test": "node scripts/load-test.mjs",
    "load-test:notifications": "node scripts/notification-load-test.mjs",
    "load-test:pos:prepare": "node scripts/k6/prepare-pos-load.mjs",
    "load-test:pos": "k6 run scripts/k6/pos-concurrent-sales.js",
    "load-test:pos:node": "node scripts/k6/run-pos-load.mjs",
    "audit:stable-rpcs": "node scripts/audit-stable-write-rpcs.mjs",
    "audit:rls": "node scripts/audit-rls-org-access.mjs",
    "audit:api-auth": "node scripts/audit-api-auth.mjs",
    "audit:financials-scope": "node scripts/audit-financials-area-scope.mjs",
    "audit:e2e": "node scripts/audit-e2e-specs.mjs",
    "audit:module-e2e": "node scripts/audit-module-e2e-matrix.mjs",
    "audit:launch-ops": "node scripts/audit-launch-ops.mjs",
    "audit:pos-a11y:install": "playwright install chromium",
    "deploy:preview": "npx vercel@latest deploy --yes",
    "deploy:live": "node scripts/deploy-live.mjs",
    "deploy:live:raw": "npx --yes vercel@latest deploy --prod --yes",
    "deploy:preprod": "npm run deploy:live",
    "deploy:preprod:prod": "npm run deploy:live",
    "test:e2e": "playwright test",
    "test:e2e:financials": "playwright test e2e/financials-scroll.spec.ts",
    "test:e2e:procure": "playwright test e2e/procure-to-pay.spec.ts",
    "test:e2e:invoice": "playwright test e2e/invoice-create.spec.ts",
    "test:e2e:permissions": "playwright test e2e/permissions.spec.ts",
    "test:e2e:install": "playwright install chromium",
    "test:unit": "vitest run packages/shared/src apps/web/src/lib",
    "test:unit:coverage": "vitest run --coverage packages/shared/src apps/web/src/lib",
    "test:integration": "vitest run tests/integration",
    "test": "npm run test:unit && npm run test:integration",
    "verify:production-env": "node scripts/verify-production-env.mjs",
    "ensure:local-launch-env": "node scripts/ensure-local-launch-env.mjs",
    "setup:launch-ops": "node scripts/setup-launch-ops.mjs",
    "setup:launch-ops:github": "node scripts/setup-launch-ops.mjs --apply-github-secrets"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@vitest/coverage-v8": "^3.2.7",
    "axe-core": "^4.12.1",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@sentry/browser": "^10.64.0"
  }
}
