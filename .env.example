NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# Local dev (optional — default fallback is http://localhost:3003)
# NEXT_PUBLIC_APP_URL=http://localhost:3003
# Server-only (Vercel → Settings → Environment Variables)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Webhooks + Vercel Cron (Hobby: once daily at 06:00 UTC; Pro can use */5 * * * *)
POS_WEBHOOK_SECRET=your-webhook-secret
CRON_SECRET=your-cron-secret
# Distributed rate limits across Vercel instances (required for production — https://upstash.com)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
# Optional: read replica + pooler for reporting/scripts (Supabase Pro)
# SUPABASE_READ_URL=https://your-read-replica.supabase.co
# NEXT_PUBLIC_SUPABASE_READ_URL=https://your-read-replica.supabase.co
# SUPABASE_POOLER_URL=postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres
# FORCE_SALES_ARCHIVE=true   # always archive cold sales on each maintenance run
# SKIP_SALES_ARCHIVE=true    # never archive (overrides Sunday auto-archive)
# Optional error monitoring (https://sentry.io)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# Load testing (scripts/k6)
LOAD_TEST_EMAIL=loadtest@example.com
LOAD_TEST_PASSWORD=your-test-password
LOAD_TEST_MIN_STOCK=2000
# E2E smoke (Playwright — login → POS sale → sales list)
E2E_EMAIL=owner@example.com
E2E_PASSWORD=your-test-password
E2E_STAFF_PIN=1234
# E2E_BASE_URL=https://nexus-erp-preprod.vercel.app
