NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Public app URL for auth redirects (Vercel pre-prod or local dev)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# Local: NEXT_PUBLIC_APP_URL=http://localhost:3003
# Server-only (Vercel → Settings → Environment Variables)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-publishable-key
# SUPABASE_SERVICE_ROLE_KEY=
# POS_WEBHOOK_SECRET=
# CRON_SECRET=              # Vercel Cron auth for /api/webhooks/process-queue
# SUPABASE_POOLER_URL=      # Direct Postgres pooler (port 6543) for CLI/scripts only
# SUPABASE_READ_URL=        # Read replica URL for reporting (Supabase Pro) — optional
# SENTRY_DSN=               # Optional error monitoring
# NEXT_PUBLIC_SENTRY_DSN=
# UPSTASH_REDIS_REST_URL=   # Optional — shared rate limits across Vercel instances (Upstash)
# UPSTASH_REDIS_REST_TOKEN=
# Legacy name (optional fallback):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# E2E_EMAIL=
# E2E_PASSWORD=
# E2E_STAFF_PIN=
# E2E_CASHIER_EMAIL=          # Optional — permission-matrix cashier user
# E2E_CASHIER_PASSWORD=
# Arifpay → Telebirr (see docs/ARIFPAY.md)
# ARIFPAY_API_KEY=
# ARIFPAY_BENEFICIARY_ACCOUNT=
# ARIFPAY_BENEFICIARY_BANK=
# ARIFPAY_SANDBOX=true
# NEXT_PUBLIC_ARIFPAY_ENABLED=true
